[node name="RichTextLabel" type="RichTextLabel" parent="Panel" unique_id=910032346]
layout_mode = 0
offset_left = 14.0
offset_top = 14.0
offset_right = 494.0
offset_bottom = 457.0
text = "The first time I flew, every pigeon in the park stopped eating.
“Wow. You are weird. That isn’t how a bird flies.”
They were right.
I didn’t glide. I didn’t flap.
I hovered, wobbled, and chopped through the air like the human machine.
So the flock left me behind.
Then the geese attacked.
Now the \"day birds\" are almost extinct, and only a few pigeon eggs remain.
The crows say they can make me stronger, if I bring them things worth trading.
Whether it’s soaring through the air, gambling with crows, or fighting with geese, the only way forward is to spin."
scroll_active = false
shortcut_keys_enabled = false

