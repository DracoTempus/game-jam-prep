[gd_scene load_steps=5 format=3]

; The shared side-scroller base level. The node layout mirrors the
; organised structure Matthew's layout plugin sets up (Systems / World /
; Effects / HUD / Pause / Debug) so everyone's work has an obvious home:
;
;   Systems   -> spawners, managers, autoload-ish helpers
;   World     -> everything in the game world
;     Background -> parallax / sky (does not scroll 1:1)
;     Level      -> ground, borders, props (the static world)
;     Entities   -> the player, enemies, projectiles (the moving things)
;   Effects   -> particles, screen shake targets, transient visuals
;   HUDLayer  -> score / health / on-screen UI
;   PauseLayer / DebugLayer -> pause menu, debug overlays

[ext_resource type="PackedScene" path="res://Entities/Player/Player.tscn" id="1"]
[ext_resource type="PackedScene" path="res://Entities/Props/Tree.tscn" id="2"]

[sub_resource type="RectangleShape2D" id="ground_shape"]
size = Vector2(2400, 160)

